	<brief_description>
		Wraps the [code]XR_FB_color_space[/code] extension.
	</brief_description>
	<description>
		Wraps the [code]XR_FB_color_space[/code] extension.
	</description>
	<tutorials>
	</tutorials>
	<methods>
